# Claude Code files are intentionally VERSIONED (not ignored):
# .claude/ (skills, agents, hooks, settings, regression map), .superpowers/,
# and .analyze-page/ are tracked so a fresh clone gets them.

# Playwright MCP artifacts (transient snapshots, console/network logs, screenshots)
.playwright-mcp/

# Session screenshots and test artifacts in project root
/*.png
/*.svg
/*.exe
/*.jpg
/*.jpeg

# Development-only — not needed on PythonAnywhere
# tests/ are versioned; ignore only local artifacts (see retro 2026-06-18)
/tests/**/__pycache__/
/tests/.pytest_cache/
/htmlcov/
/scripts/
pytest.ini

# Temporary files
*.tmp
*.bak
*.backup

# Static files collected
/static_collected/

# Prevent clutter in project root
# All scripts should be in ../../scripts/cas/
/*.html
/mockup/
/seed_*.py
/test_*.py
/create_*.py
/check_*.py
/clear_*.py
/verify_*.py
/generate_*.py
nul
