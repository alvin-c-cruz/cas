*~

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Claude Code files are VERSIONED so a fresh clone gets them: skills, agents,
# hooks, guard.py, regression-map.json and settings under .claude/, plus the
# .analyze-page/ history. Only transient Claude runtime artifacts are ignored:
# (.gitignore has no inline comments — keep patterns on their own lines)
# .superpowers/ = per-session brainstorm scratch + logs
.superpowers/
# .claude/scheduled_tasks.lock = transient scheduler lock
.claude/scheduled_tasks.lock

# Playwright MCP artifacts (transient snapshots, console/network logs, screenshots)
.playwright-mcp/

# Session screenshots and test artifacts in project root
/*.png
/*.svg
/*.exe
/*.jpg
/*.jpeg

# Development-only — not needed on PythonAnywhere
# tests/ are versioned; ignore only local artifacts (see retro 2026-06-18)
/tests/**/__pycache__/
/tests/.pytest_cache/
/htmlcov/
/scripts/
pytest.ini

# Temporary files
*.tmp
*.bak
*.backup

# Static files collected
/static_collected/

# Prevent clutter in project root
# All scripts should be in ../../scripts/cas/
/*.html
/mockup/
/seed_*.py
/test_*.py
/create_*.py
/check_*.py
/clear_*.py
/verify_*.py
/generate_*.py
nul

.analyze-page/
