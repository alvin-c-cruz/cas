# CAS Application Environment Variables
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!

# Flask Configuration
FLASK_APP=flask_app.py
FLASK_ENV=development
FLASK_DEBUG=1

# Security
# Generate a strong secret key using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# Database
# Each deployment points at its OWN database file. Same codebase, different data:
#   RIC client server   -> sqlite:///ric.db
#   CAS demo server      -> sqlite:///cas_demo.db
# See docs/superpowers/specs/2026-06-21-ric-cas-database-separation-design.md
SQLALCHEMY_DATABASE_URI=sqlite:///cas.db

# Production (PostgreSQL example)
# SQLALCHEMY_DATABASE_URI=postgresql://username:password@localhost/cas_db

# Session Security
SESSION_COOKIE_SECURE=False  # Set to True in production with HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=43200  # 12 hours in seconds

# Application Settings
MAX_CONTENT_LENGTH=16777216  # 16MB max upload size
