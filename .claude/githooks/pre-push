#!/bin/sh
# CAS regression guard — pre-push gate.
#
# Blocks a push when a high-blast-radius shared file changed AND the affected module's
# Playwright e2e smoke now fails (a silent JS-layer regression). Fast pass-through when no
# blast-radius file changed. Enable once with:
#   git config core.hooksPath .claude/githooks
# Escape hatch:  GUARD_SKIP=1 git push
if [ "$GUARD_SKIP" = "1" ]; then
  echo "[guard] GUARD_SKIP=1 — skipping pre-push regression gate."
  exit 0
fi

python .claude/guard.py --run-e2e
rc=$?
if [ "$rc" != "0" ]; then
  echo "[guard] Push blocked by regression gate (exit $rc). Run /guard for detail."
fi
exit $rc
